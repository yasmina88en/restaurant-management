{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/dashboard.css') }}?v=2">
<link rel="stylesheet" href="{{ asset('css/orders.css') }}?v=2">
{% endblock %}

{% block body %}
<header class="top-bar">
    <div class="brand">
        <img src="{{ asset('images/logo.png') }}" alt="Logo">>
        <div>
            <h2>Restaurant Admin</h2>
            <span>Management System</span>
        </div>
    </div>
    <a href="{{ path('app_logout') }}" class="logout">Logout</a>
</header>

<nav class="menu">
    <a href="{{ path('admin_dashboard') }}">Dashboard</a>
    <a href="{{ path('category_index') }}">Categories</a>
    <a href="{{ path('dish_index') }}">Dishes</a>
    <a href="{{ path('admin_order_index') }}" class="active">Orders</a>
</nav>

<div class="container">
    <h1>Orders</h1>

    {% for order in orders %}
        <div class="order-card">
            <div class="order-header">
                <h3>Order #{{ order.id }}</h3>
                <span>{{ order.createdAt|date('d/m/Y H:i') }}</span>
            </div>

            <div class="order-info">
                <p><strong>Customer:</strong> {{ order.customerName }}</p>
                <p><strong>Phone:</strong> {{ order.customerPhone }}</p>
                <p><strong>Address:</strong> {{ order.customerAddress }}</p>
                <p class="total"><strong>Total:</strong> ${{ order.totalPrice }}</p>
            </div>

            <a href="{{ path('admin_order_show', {'id': order.id}) }}" class="btn-view">View Details</a>
        </div>
    {% else %}
        <p class="empty">No orders yet.</p>
    {% endfor %}
</div>
{% endblock %}