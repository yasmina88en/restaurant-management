{% extends 'base.html.twig' %}

{% block title %}Edit Category{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}?v=2">
    <link rel="stylesheet" href="{{ asset('css/form.css') }}?v=2">
{% endblock %}

{% block body %}
<header class="top-bar">
    <div class="brand">
         <img src="{{ asset('images/logo.png') }}" alt="Logo">
        <div>
            <h2>Restaurant Admin</h2>
            <span>Management System</span>
        </div>
    </div>
    <a href="{{ path('app_login') }}" class="logout">Logout</a>
</header>

<nav class="menu">
    <a href="{{ path('admin_dashboard') }}">Dashboard</a>
    <a href="{{ path('category_index') }}" class="active">Categories</a>
    <a href="{{ path('dish_index') }}">Dishes</a> 
    <a href="{{ path('admin_order_index')}}">Orders</a>
</nav>

<div class="container">
    <div class="form-header">
        <h1>Edit Category</h1>
        <a href="{{ path('category_index') }}" class="btn-back">← Back to Categories</a>
    </div>

    <div class="form-container">
        {{ form_start(form, {'attr': {'id': 'editForm', 'enctype': 'multipart/form-data', 'onsubmit': 'return confirmBeforeSubmit()'}}) }}
            <div class="form-group">
                {{ form_label(form.name, 'Category Name') }}
                {{ form_widget(form.name, {'attr': {'class': 'form-input', 'placeholder': 'Enter category name'}}) }}
                {{ form_errors(form.name) }}
            </div>

            {% if category.image %}
            <div class="current-image">
                <p>Current Image:</p>
                <img src="{{ asset('images/' ~ category.image) }}" alt="{{ category.name }}">
            </div>
            {% endif %}

            <div class="form-group">
                <label>Change Image (optional)</label>
                <div class="file-upload-box" onclick="document.getElementById('category_image').click()">
                    <span id="fileName">📁 Click here to choose a new image...</span>
                </div>
                {{ form_widget(form.image, {'attr': {'style': 'display:none', 'id': 'category_image'}}) }}
                {{ form_errors(form.image) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('category_index') }}" class="btn-cancel">Cancel</a>
                {{ form_widget(form.save, {'attr': {'class': 'btn-save'}, 'label': 'Update Category'}) }}
            </div>
        {{ form_end(form) }}
    </div>
</div>

<!-- Modal de confirmation -->
<div id="updateModal" class="modal">
    <div class="modal-content">
        <h3>Confirm Update</h3>
        <p>Are you sure you want to update <strong>{{ category.name }}</strong>?</p>
        <div class="modal-actions">
            <button type="button" onclick="closeUpdateModal()" class="btn-cancel">Cancel</button>
            <button type="button" onclick="proceedUpdate()" class="btn-confirm">Confirm</button>
        </div>
    </div>
</div>

<script>
let formSubmitAllowed = false;

document.getElementById('category_image').addEventListener('change', function(e) {
    const fileName = document.getElementById('fileName');
    if (this.files && this.files[0]) {
        fileName.textContent = '✅ ' + this.files[0].name;
        fileName.style.color = '#28a745';
    } else {
        fileName.textContent = '📁 Click here to choose a new image...';
        fileName.style.color = '#666';
    }
});

function confirmBeforeSubmit() {
    if (formSubmitAllowed) {
        return true;
    }
    
    document.getElementById('updateModal').style.display = 'flex';
    return false;
}

function closeUpdateModal() {
    document.getElementById('updateModal').style.display = 'none';
}

function proceedUpdate() {
    closeUpdateModal();
    formSubmitAllowed = true;
    document.getElementById('editForm').submit();
}

window.onclick = function(event) {
    const modal = document.getElementById('updateModal');
    if (event.target == modal) {
        closeUpdateModal();
    }
}
</script>
{% endblock %}